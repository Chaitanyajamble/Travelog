@reviews_router.post("", response_model=ReviewOut, status_code=201)
async def submit_review(
    body: ReviewCreate,
    current_user=Depends(get_current_user),
    db: Session = Depends(get_db),
):
    if not body.tour_id and not body.package_id:
        raise HTTPException(status_code=400, detail="Provide either tour_id or package_id")

    # only allow reviews from users who actually booked the product
    has_booking = False
    for item in (
        db.query(BookingItem)
        .join(Booking)
        .filter(Booking.user_id == current_user.id)
        .all()
    ):
        if body.tour_id and item.tour_id == body.tour_id:
            has_booking = True
            break
        if body.package_id and item.package_id == body.package_id:
            has_booking = True
            break

    if not has_booking:
        raise HTTPException(
            status_code=403,
            detail="You can only review products you have booked",
        )

    review = Review(
        user_id=current_user.id,
        tour_id=body.tour_id,
        package_id=body.package_id,
        rating=body.rating,
        title=body.title,
        body=body.body,
    )
    db.add(review)
    db.commit()
    db.refresh(review)

    # run LLM sentiment analysis in background
    try:
        sentiment, summary = await analyze_review_sentiment(body.body, body.rating)
        review.ai_sentiment = sentiment
        review.ai_summary = summary
        db.add(review)
        db.commit()
    except Exception:
        pass

    return review


