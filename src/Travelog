            joinedload(HolidayPackage.destination_city),
            joinedload(HolidayPackage.pricing_options),
            joinedload(HolidayPackage.images),
        )
        .filter(HolidayPackage.is_active == True, HolidayPackage.is_featured == True)
        .limit(6)
        .all()
    )
    flash_tours = (
        db.query(Tour)
        .options(joinedload(Tour.city), joinedload(Tour.pricing_options), joinedload(Tour.images))
        .filter(Tour.is_active == True, Tour.is_flash_sale == True)
        .limit(6)
        .all()
    )
    flash_packages = (
        db.query(HolidayPackage)
        .options(
            joinedload(HolidayPackage.destination_city),
            joinedload(HolidayPackage.pricing_options),
            joinedload(HolidayPackage.images),
        )
        .filter(HolidayPackage.is_active == True, HolidayPackage.is_flash_sale == True)
        .limit(6)
        .all()
    )

    return {
        "popular_destinations": [CityOut.model_validate(c).model_dump() for c in popular_cities],
        "featured_tours": [_serialize_tour(t) for t in featured_tours],
        "featured_packages": [_serialize_pkg(p) for p in featured_packages],
        "flash_sale_tours": [_serialize_tour(t) for t in flash_tours],
        "flash_sale_packages": [_serialize_pkg(p) for p in flash_packages],
    }


