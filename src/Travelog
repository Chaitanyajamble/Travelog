def _serialize_tour(tour: Tour) -> dict:
    cover = next((img.url for img in tour.images if img.is_cover), None) or (
        tour.images[0].url if tour.images else None
    )
    prices = [opt.discounted_price or opt.original_price for opt in tour.pricing_options]
    return {
        "id": tour.id,
        "title": tour.title,
        "slug": tour.slug,
        "ai_summary": tour.ai_summary,
        "city": tour.city.name if tour.city else None,
        "duration_hours": float(tour.duration_hours) if tour.duration_hours else None,
        "cover_image": cover,
        "starting_price": float(min(prices)) if prices else None,
        "is_flash_sale": tour.is_flash_sale,
        "flash_sale_ends_at": tour.flash_sale_ends_at.isoformat() if tour.flash_sale_ends_at else None,
        "is_featured": tour.is_featured,
        "product_type": "tour",
    }


def _serialize_pkg(pkg: HolidayPackage) -> dict:
    cover = next((img.url for img in pkg.images if img.is_cover), None) or (
        pkg.images[0].url if pkg.images else None
    )
    prices = [opt.discounted_price or opt.original_price for opt in pkg.pricing_options]
    return {
        "id": pkg.id,
        "title": pkg.title,
        "slug": pkg.slug,
        "ai_summary": pkg.ai_summary,
        "origin_city": pkg.origin_city,
        "destination": pkg.destination_city.name if pkg.destination_city else None,
        "duration_days": pkg.duration_days,
        "duration_nights": pkg.duration_nights,
        "cover_image": cover,
        "starting_price": float(min(prices)) if prices else None,
        "is_flash_sale": pkg.is_flash_sale,
        "flash_sale_ends_at": pkg.flash_sale_ends_at.isoformat() if pkg.flash_sale_ends_at else None,
        "is_featured": pkg.is_featured,
        "product_type": "holiday_package",
    }
