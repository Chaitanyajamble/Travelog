@router.post("/initiate", response_model=dict)
def initiate_payment(
    body: PaymentInitiate,
    current_user=Depends(get_current_user),
    db: Session = Depends(get_db),
):
    booking = db.query(Booking).filter(
        Booking.id == body.booking_id, Booking.user_id == current_user.id
    ).first()
    if not booking:
        raise HTTPException(status_code=404, detail="Booking not found")
    if booking.status not in (BookingStatus.pending,):
        raise HTTPException(status_code=400, detail="Booking is not in a payable state")

    # check if a payment record already exists
    existing = db.query(Payment).filter(Payment.booking_id == booking.id).first()
    if existing and existing.status == PaymentStatus.paid:
        raise HTTPException(status_code=400, detail="Booking already paid")

    method = body.method.lower()

    if method == "card":
        return _initiate_stripe(booking, db)
    elif method == "fpx":
        return _initiate_fpx(booking, db)
    elif method == "bank_transfer":
        return _initiate_bank_transfer(booking, db)
    else:
        raise HTTPException(status_code=400, detail=f"Unsupported payment method: {method}")


def _initiate_stripe(booking: Booking, db: Session) -> dict:
    intent = stripe.PaymentIntent.create(
        amount=int(booking.total_amount * 100),   # Stripe uses cents
        currency=booking.currency.lower(),
        metadata={"booking_id": booking.id, "reference": booking.reference_number},
        description=f"Travelog booking {booking.reference_number}",
    )

    payment = _get_or_create_payment(db, booking, PaymentMethod.card)
    payment.gateway_reference = intent["id"]
    db.add(payment)
    db.commit()

    return {
        "method": "card",
        "client_secret": intent["client_secret"],
        "payment_intent_id": intent["id"],
    }


def _initiate_fpx(booking: Booking, db: Session) -> dict:
    # build the FPX form data — each FPX bank has a specific flow, this is a simplified version
    payment = _get_or_create_payment(db, booking, PaymentMethod.fpx)
    db.add(payment)
    db.commit()

    # in production you'd construct the FPX checksum and redirect URL here
    fpx_url = (
        f"{settings.fpx_api_url}/pay?"
        f"merchant_id={settings.fpx_merchant_id}"
        f"&order_id={booking.reference_number}"
        f"&amount={booking.total_amount}"
        f"&currency={booking.currency}"
    )
    return {
        "method": "fpx",
        "redirect_url": fpx_url,
        "reference_number": booking.reference_number,
    }


def _initiate_bank_transfer(booking: Booking, db: Session) -> dict:
    payment = _get_or_create_payment(db, booking, PaymentMethod.bank_transfer)
    db.add(payment)
    db.commit()
    return {
