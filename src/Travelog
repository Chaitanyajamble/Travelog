@router.get("/search")
def search(
    q: str = Query(..., min_length=2),
    product_type: Optional[str] = Query(None),
    city_id: Optional[int] = Query(None),
    category_id: Optional[int] = Query(None),
    min_price: Optional[Decimal] = Query(None),
    max_price: Optional[Decimal] = Query(None),
    is_flash_sale: Optional[bool] = Query(None),
    sort_by: str = Query("featured"),
    page: int = Query(1, ge=1),
    page_size: int = Query(20, ge=1, le=100),
    db: Session = Depends(get_db),
):
    search_term = f"%{q}%"
    tours = []
    packages = []

    if not product_type or product_type == "tour":
        tour_query = (
            db.query(Tour)
            .options(joinedload(Tour.city), joinedload(Tour.pricing_options), joinedload(Tour.images))
            .filter(
                Tour.is_active == True,
                or_(Tour.title.ilike(search_term), Tour.description.ilike(search_term)),
            )
        )
        if city_id:
            tour_query = tour_query.filter(Tour.city_id == city_id)
        if category_id:
            tour_query = tour_query.filter(Tour.category_id == category_id)
        if is_flash_sale is not None:
            tour_query = tour_query.filter(Tour.is_flash_sale == is_flash_sale)
        tours = tour_query.limit(page_size).offset((page - 1) * page_size).all()

    if not product_type or product_type == "holiday_package":
        pkg_query = (
            db.query(HolidayPackage)
            .options(
                joinedload(HolidayPackage.destination_city),
                joinedload(HolidayPackage.pricing_options),
                joinedload(HolidayPackage.images),
            )
            .filter(
                HolidayPackage.is_active == True,
                or_(
                    HolidayPackage.title.ilike(search_term),
                    HolidayPackage.description.ilike(search_term),
                ),
            )
        )
        if city_id:
            pkg_query = pkg_query.filter(HolidayPackage.destination_city_id == city_id)
        if is_flash_sale is not None:
            pkg_query = pkg_query.filter(HolidayPackage.is_flash_sale == is_flash_sale)
        packages = pkg_query.limit(page_size).offset((page - 1) * page_size).all()

    return {
        "query": q,
        "total_tours": len(tours),
        "total_packages": len(packages),
        "tours": [_serialize_tour(t) for t in tours],
        "packages": [_serialize_pkg(p) for p in packages],
    }


