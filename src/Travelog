# ─── tour / package summaries ─────────────────────────────────────

async def generate_tour_summary(
    title: str,
    description: str,
    inclusions: List[str],
) -> str:
    """
    Generate a punchy 2–3 sentence highlight summary of a tour
    that can be shown in search result cards.
    """
    inclusions_text = ", ".join(inclusions[:6]) if inclusions else "not specified"

    response = await client.chat.completions.create(
        model=MODEL,
        messages=[
            {
                "role": "system",
                "content": (
                    "You are a travel copywriter for Travelog, a Malaysian tours and activities platform. "
                    "Write engaging, accurate summaries that make travellers excited to book. "
                    "Keep it to 2-3 sentences. No fluff, no 'embark on a journey' clichés."
                ),
            },
            {
                "role": "user",
                "content": (
                    f"Summarise this tour for a search result card:\n\n"
                    f"Title: {title}\n"
                    f"Description: {description[:1000]}\n"
                    f"What's included: {inclusions_text}"
                ),
            },
        ],
        max_tokens=150,
        temperature=0.7,
    )
    return response.choices[0].message.content.strip()


async def generate_package_summary(
    title: str,
    description: str,
    itinerary: List[dict],
    inclusions: List[str],
) -> str:
    """Generate a short holiday package summary for listing cards."""
    day_titles = [d.get("title", "") for d in (itinerary or [])[:3]]
    day_str = ", ".join(day_titles) if day_titles else "various activities"
    inclusions_text = ", ".join((inclusions or [])[:5])

    response = await client.chat.completions.create(
        model=MODEL,
        messages=[
            {
                "role": "system",
                "content": (
                    "You write concise, enticing holiday package summaries for a travel booking platform. "
                    "2-3 sentences max. Mention the highlights, duration feel, and one standout inclusion."
                ),
            },
            {
                "role": "user",
                "content": (
                    f"Package: {title}\n"
                    f"Description: {description[:800]}\n"
                    f"Sample itinerary highlights: {day_str}\n"
                    f"Inclusions: {inclusions_text}"
                ),
            },
        ],
        max_tokens=150,
        temperature=0.7,
    )
    return response.choices[0].message.content.strip()


# ─── review sentiment ─────────────────────────────────────────────

async def analyze_review_sentiment(body: str, rating: int) -> Tuple[str, str]:
    """
    Returns (sentiment_label, one_line_summary).
    sentiment_label is one of: positive, neutral, negative, mixed.
    """
    response = await client.chat.completions.create(
        model=MODEL,
        messages=[
            {
                "role": "system",
                "content": (
                    "You analyse travel reviews and return a JSON object with two keys:\n"
                    '- "sentiment": one of "positive", "neutral", "negative", or "mixed"\n'
                    '- "summary": a single sentence summarising the reviewer\'s experience\n'
                    "Return valid JSON only, no markdown."
                ),
            },
            {
                "role": "user",
                "content": f"Rating: {rating}/5\nReview: {body[:1500]}",
            },
        ],
        max_tokens=100,
        temperature=0.2,
        response_format={"type": "json_object"},
    )
    result = json.loads(response.choices[0].message.content)
    return result.get("sentiment", "neutral"), result.get("summary", "")


# ─── contact triage ───────────────────────────────────────────────

async def triage_contact_submission(
    subject: str,
    message: str,
    booking_ref: Optional[str] = None,
) -> Tuple[str, str]:
    """
    Categorise a customer support message and draft a helpful first-pass reply.
    Returns (category, draft_reply).
    Categories: refund, date_change, voucher, booking_inquiry, general, complaint, payment.
    """
    ref_line = f"Booking reference: {booking_ref}" if booking_ref else ""
    prompt = f"Subject: {subject}\n{ref_line}\nMessage: {message[:2000]}"

    response = await client.chat.completions.create(
        model=MODEL,
        messages=[
            {
                "role": "system",
                "content": (
                    "You are a customer support assistant for Travelog, a Malaysian tour and holiday booking platform. "
                    "Travelog's key policies: no cancellations (date changes allowed), vouchers are emailed after payment, "
                    "refunds only if merchant closes or if booking confirmation wasn't delivered due to Travelog's fault.\n\n"
                    "Given a customer message, return a JSON object with:\n"
                    '- "category": one of refund, date_change, voucher, booking_inquiry, general, complaint, payment\n'
                    '- "draft_reply": a polite, helpful draft reply in English that a human agent can edit and send\n'
                    "Return valid JSON only."
                ),
            },
            {"role": "user", "content": prompt},
        ],
        max_tokens=400,
        temperature=0.3,
        response_format={"type": "json_object"},
    )
    result = json.loads(response.choices[0].message.content)
    return result.get("category", "general"), result.get("draft_reply", "")


# ─── personalised recommendations ────────────────────────────────

async def get_travel_recommendations(
    departure_city: Optional[str],
    interests: Optional[List[str]],
    budget_range: Optional[str],
    trip_duration: Optional[str],
    travel_date: Optional[str],
    additional_context: Optional[str],
) -> dict:
    """
    Returns structured travel recommendations.
    The LLM suggests destination types and activity categories;
    the actual product matching happens in the endpoint layer.
    """
    parts = []
    if departure_city:
        parts.append(f"Departing from: {departure_city}")
    if interests:
        parts.append(f"Interests: {', '.join(interests)}")
    if budget_range:
        parts.append(f"Budget: {budget_range}")
    if trip_duration:
        parts.append(f"Trip duration: {trip_duration}")
    if travel_date:
        parts.append(f"Travel date: {travel_date}")
    if additional_context:
        parts.append(f"Additional context: {additional_context}")

    user_input = "\n".join(parts) if parts else "No specific preferences provided"

    response = await client.chat.completions.create(
        model=MODEL,
        messages=[
            {
                "role": "system",
                "content": (
                    "You are a knowledgeable Malaysian travel advisor. "
                    "Based on traveller preferences, recommend suitable destinations and experience types. "
                    "Focus on Malaysia and nearby Southeast Asian destinations. "
                    "Return a JSON object with:\n"
                    '- "destinations": list of 3-5 city/country names\n'
                    '- "activity_types": list of activity categories (e.g. "beach", "culture", "adventure")\n'
                    '- "reasoning": 2-3 sentence explanation of why these suit the traveller\n'
                    '- "tips": 2-3 practical travel tips\n'
                    "Return valid JSON only."
                ),
            },
            {"role": "user", "content": user_input},
        ],
        max_tokens=500,
        temperature=0.6,
        response_format={"type": "json_object"},
    )
    return json.loads(response.choices[0].message.content)


# ─── travel chat assistant ────────────────────────────────────────

async def travel_chat(
    user_message: str,
    conversation_history: List[dict],
) -> Tuple[str, List[str], List[str]]:
    """
    Multi-turn conversational travel assistant.
    Returns (reply_text, suggested_tour_slugs, suggested_package_slugs).
    """
    system_prompt = (
        "You are TravelBot, a friendly and knowledgeable travel assistant for Travelog — "
        "a Malaysian platform that sells tours, sightseeing activities, and holiday packages across Southeast Asia. "
        "Help users plan their trip, answer questions about destinations, and suggest relevant products from our catalogue. "
        "When you want to recommend a specific tour or package, output a line like:\n"
        "  SUGGEST_TOUR:<slug> or SUGGEST_PACKAGE:<slug>\n"
        "Otherwise just chat naturally. Keep responses concise — under 150 words unless the user asks for detail."
    )

    messages = [{"role": "system", "content": system_prompt}]
    # include last 10 turns to stay within token budget
    messages.extend(conversation_history[-10:])
    messages.append({"role": "user", "content": user_message})

    response = await client.chat.completions.create(
        model=MODEL,
        messages=messages,
        max_tokens=400,
        temperature=0.7,
    )
    reply = response.choices[0].message.content.strip()

    # parse any product suggestions out of the reply
    tour_slugs = []
    package_slugs = []
    clean_lines = []
    for line in reply.split("\n"):
        if line.startswith("SUGGEST_TOUR:"):
            tour_slugs.append(line.replace("SUGGEST_TOUR:", "").strip())
        elif line.startswith("SUGGEST_PACKAGE:"):
            package_slugs.append(line.replace("SUGGEST_PACKAGE:", "").strip())
        else:
            clean_lines.append(line)

    clean_reply = "\n".join(clean_lines).strip()
    return clean_reply, tour_slugs, package_slugs


