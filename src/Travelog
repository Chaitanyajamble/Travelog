# ─── helpers ─────────────────────────────────────────────────────

def _get_or_create_payment(db: Session, booking: Booking, method: PaymentMethod) -> Payment:
    payment = db.query(Payment).filter(Payment.booking_id == booking.id).first()
    if not payment:
        payment = Payment(
            booking_id=booking.id,
            amount=booking.total_amount,
            currency=booking.currency,
            method=method,
        )
    else:
        payment.method = method
    return payment


def _handle_payment_success(
    booking_id: str,
    gateway_reference: str,
    gateway_response: dict,
    db: Session,
):
    booking = db.query(Booking).filter(Booking.id == booking_id).first()
    if not booking:
        return

    booking.status = BookingStatus.confirmed
    db.add(booking)

    payment = db.query(Payment).filter(Payment.booking_id == booking_id).first()
    if payment:
        payment.status = PaymentStatus.paid
        payment.gateway_reference = gateway_reference
        payment.gateway_response = gateway_response
        payment.paid_at = datetime.utcnow()
        db.add(payment)

    db.commit()

    # send payment confirmation and issue vouchers
    send_payment_confirmation_email(
        booking.contact_email, booking.contact_name, booking.reference_number, booking.total_amount
    )
    issue_vouchers_for_booking(booking.id, db)

    notif = Notification(
        user_id=booking.user_id,
        type=NotificationType.payment_received,
        title="Payment confirmed",
        message=f"Payment for booking {booking.reference_number} has been confirmed.",
        metadata={"booking_id": booking_id},
    )
    db.add(notif)
    db.commit()
