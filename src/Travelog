    admin: User = Depends(require_admin),
):
    pkg = db.query(HolidayPackage).filter(HolidayPackage.id == package_id).first()
    if not pkg:
        raise HTTPException(status_code=404, detail="Package not found")
    pkg.is_active = False
    db.add(pkg)
    db.commit()


@router.post("/{package_id}/images", status_code=201)
async def upload_package_image(
    package_id: str,
    file: UploadFile = File(...),
    is_cover: bool = False,
    db: Session = Depends(get_db),
    admin: User = Depends(require_admin),
):
    pkg = db.query(HolidayPackage).filter(HolidayPackage.id == package_id).first()
    if not pkg:
        raise HTTPException(status_code=404, detail="Package not found")

    contents = await file.read()
    url = upload_file_to_s3(contents, file.filename, file.content_type, folder=f"packages/{package_id}")

    if is_cover:
        db.query(PackageImage).filter(
            PackageImage.package_id == package_id, PackageImage.is_cover == True
        ).update({"is_cover": False})

    img = PackageImage(package_id=package_id, url=url, is_cover=is_cover)
    db.add(img)
    db.commit()
    return {"url": url, "id": img.id}


@router.post("/{package_id}/departures", status_code=201)
def add_departure(
    package_id: str,
    body: PackageDepartureOut,
    db: Session = Depends(get_db),
    admin: User = Depends(require_admin),
):
    dep = PackageDeparture(
        package_id=package_id,
        departure_date=body.departure_date,
        return_date=body.return_date,
        available_seats=body.available_seats,
    )
    db.add(dep)
    db.commit()
    return {"id": dep.id}


def _merge(pkg: HolidayPackage) -> dict:
    d = PackageDetailOut.model_validate(pkg).model_dump()
    d.update(_enrich_pkg(pkg))
    return d
