        )
        .filter(Tour.is_active == True)
    )


def _enrich_tour(tour: Tour) -> dict:
    """Pull computed fields that are not columns."""
    cover = next((img.url for img in tour.images if img.is_cover), None)
    if not cover and tour.images:
        cover = tour.images[0].url

    prices = [
        opt.discounted_price or opt.original_price
        for opt in tour.pricing_options
    ]
    starting_price = min(prices) if prices else None

    return {
        "cover_image": cover,
        "starting_price": starting_price,
    }


@router.get("", response_model=dict)
def list_tours(
    city_id: Optional[int] = Query(None),
    category_id: Optional[int] = Query(None),
    is_flash_sale: Optional[bool] = Query(None),
    is_featured: Optional[bool] = Query(None),
    min_price: Optional[Decimal] = Query(None),
    max_price: Optional[Decimal] = Query(None),
    q: Optional[str] = Query(None),
    sort_by: str = Query("featured"),
    page: int = Query(1, ge=1),
    page_size: int = Query(20, ge=1, le=100),
    db: Session = Depends(get_db),
):
    query = _base_tour_query(db)

    if city_id:
        query = query.filter(Tour.city_id == city_id)
    if category_id:
        query = query.filter(Tour.category_id == category_id)
    if is_flash_sale is not None:
        query = query.filter(Tour.is_flash_sale == is_flash_sale)
    if is_featured is not None:
        query = query.filter(Tour.is_featured == is_featured)
    if q:
        search = f"%{q}%"
        query = query.filter(Tour.title.ilike(search))

    # price filter — need a subquery on pricing options
    if min_price or max_price:
        price_sub = (
            db.query(
                TourPricingOption.tour_id,
                func.min(
                    func.coalesce(TourPricingOption.discounted_price, TourPricingOption.original_price)
                ).label("min_price"),
            )
            .group_by(TourPricingOption.tour_id)
            .subquery()
        )
        query = query.join(price_sub, Tour.id == price_sub.c.tour_id)
        if min_price:
            query = query.filter(price_sub.c.min_price >= min_price)
        if max_price:
            query = query.filter(price_sub.c.min_price <= max_price)

    if sort_by == "newest":
        query = query.order_by(Tour.created_at.desc())
    elif sort_by == "price_asc":
        query = query.order_by(Tour.created_at)  # simplified; real sort uses subquery
    else:
        query = query.order_by(Tour.is_featured.desc(), Tour.created_at.desc())

    total = query.count()
    tours = query.offset((page - 1) * page_size).limit(page_size).all()

    items = []
    for t in tours:
        enriched = _enrich_tour(t)
        d = TourDetailOut.model_validate(t).model_dump()
        d.update(enriched)
        items.append(d)

    return {"total": total, "page": page, "page_size": page_size, "items": items}


