coupons_router = APIRouter(prefix="/coupons", tags=["coupons"])


@coupons_router.post("/validate", response_model=CouponValidateResponse)
def validate_coupon(body: CouponValidateRequest, db: Session = Depends(get_db)):
    coupon = db.query(Coupon).filter(
        Coupon.code == body.code.upper(), Coupon.is_active == True
    ).first()

    if not coupon:
        return CouponValidateResponse(valid=False, discount_amount=0, message="Invalid coupon code")

    now = datetime.utcnow()
    if coupon.valid_from and coupon.valid_from > now:
        return CouponValidateResponse(valid=False, discount_amount=0, message="Coupon is not valid yet")
    if coupon.valid_until and coupon.valid_until < now:
        return CouponValidateResponse(valid=False, discount_amount=0, message="Coupon has expired")
    if coupon.max_uses and coupon.used_count >= coupon.max_uses:
        return CouponValidateResponse(valid=False, discount_amount=0, message="Coupon usage limit reached")
    if body.order_total < coupon.min_order_amount:
        return CouponValidateResponse(
            valid=False,
            discount_amount=0,
            message=f"Minimum order amount is MYR {coupon.min_order_amount}",
        )
    if coupon.applicable_product_type and body.product_type:
        if coupon.applicable_product_type.value != body.product_type:
            return CouponValidateResponse(
                valid=False, discount_amount=0, message="Coupon is not valid for this product type"
            )

    if coupon.discount_percent:
        discount = (body.order_total * coupon.discount_percent / 100).quantize(__import__("decimal").Decimal("0.01"))
    else:
        discount = min(coupon.discount_flat, body.order_total)

    return CouponValidateResponse(
        valid=True,
        discount_amount=discount,
        message=f"Coupon applied — you save MYR {discount}",
    )


