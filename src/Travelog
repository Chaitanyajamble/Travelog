            ).first()
            if not pricing:
                raise HTTPException(status_code=400, detail=f"Pricing option not found for tour")
            tour = db.query(Tour).filter(Tour.id == item_data.tour_id, Tour.is_active == True).first()
            if not tour:
                raise HTTPException(status_code=400, detail="Tour not found or inactive")
            unit_price = pricing.discounted_price or pricing.original_price
            line_total = unit_price * item_data.quantity
            subtotal += line_total
            line_items.append({
                "product_type": "tour",
                "tour_id": item_data.tour_id,
                "package_id": None,
                "product_title": tour.title,
                "pricing_label": pricing.label,
                "unit_price": unit_price,
                "quantity": item_data.quantity,
                "travel_date": item_data.travel_date,
                "schedule_id": item_data.schedule_id,
                "departure_id": None,
                "line_total": line_total,
            })
        else:
            pricing = db.query(PackagePricingOption).filter(
                PackagePricingOption.id == item_data.pricing_option_id,
                PackagePricingOption.package_id == item_data.package_id,
            ).first()
            if not pricing:
                raise HTTPException(status_code=400, detail="Pricing option not found for package")
            pkg = db.query(HolidayPackage).filter(
                HolidayPackage.id == item_data.package_id, HolidayPackage.is_active == True
            ).first()
            if not pkg:
                raise HTTPException(status_code=400, detail="Package not found or inactive")
            unit_price = pricing.discounted_price or pricing.original_price
            line_total = unit_price * item_data.quantity
            subtotal += line_total
            line_items.append({
                "product_type": "holiday_package",
                "tour_id": None,
                "package_id": item_data.package_id,
                "product_title": pkg.title,
                "pricing_label": pricing.label,
                "unit_price": unit_price,
                "quantity": item_data.quantity,
                "travel_date": item_data.travel_date,
                "schedule_id": None,
                "departure_id": item_data.departure_id,
                "line_total": line_total,
            })

    # apply coupon if provided
    discount_amount = Decimal("0")
    if body.coupon_code:
        coupon = db.query(Coupon).filter(
            Coupon.code == body.coupon_code.upper(),
            Coupon.is_active == True,
        ).first()
        if not coupon:
            raise HTTPException(status_code=400, detail="Invalid or expired coupon code")
        if coupon.valid_from and coupon.valid_from > datetime.utcnow():
            raise HTTPException(status_code=400, detail="Coupon is not valid yet")
        if coupon.valid_until and coupon.valid_until < datetime.utcnow():
            raise HTTPException(status_code=400, detail="Coupon has expired")
        if coupon.max_uses and coupon.used_count >= coupon.max_uses:
            raise HTTPException(status_code=400, detail="Coupon usage limit reached")
        if subtotal < coupon.min_order_amount:
            raise HTTPException(
                status_code=400,
                detail=f"Minimum order amount for this coupon is {coupon.min_order_amount}",
            )
        if coupon.discount_percent:
            discount_amount = (subtotal * coupon.discount_percent / 100).quantize(Decimal("0.01"))
        elif coupon.discount_flat:
            discount_amount = min(coupon.discount_flat, subtotal)

        coupon.used_count += 1
        db.add(coupon)

    total = subtotal - discount_amount

    booking = Booking(
        reference_number=_generate_ref(),
        user_id=current_user.id,
        subtotal=subtotal,
        discount_amount=discount_amount,
        total_amount=total,
        contact_name=body.contact_name,
        contact_email=body.contact_email,
        contact_phone=body.contact_phone,
        coupon_code=body.coupon_code,
        notes=body.notes,
    )
    db.add(booking)
    db.flush()   # get the booking id before adding children

    for li in line_items:
        db.add(BookingItem(booking_id=booking.id, **li))

    for pax in body.passengers:
        db.add(Passenger(booking_id=booking.id, **pax.model_dump()))

    db.commit()
    db.refresh(booking)

    # send confirmation email in background
    background_tasks.add_task(
        send_booking_confirmation_email,
        body.contact_email,
        body.contact_name,
        booking.reference_number,
        total,
    )

    # create an in-app notification
    notif = Notification(
        user_id=current_user.id,
        type=NotificationType.booking_confirmed,
        title="Booking received",
        message=f"Your booking {booking.reference_number} has been received and is awaiting payment.",
        metadata={"booking_id": booking.id},
    )
    db.add(notif)
    db.commit()

    return booking


