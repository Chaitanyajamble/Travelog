    def test_flash_sale_countdown_ticks(self, driver, wait):
        homepage = HomePage(driver)
        homepage.open()

        if not homepage.is_visible(*HomePage.FLASH_SALE_COUNTDOWN):
            pytest.skip("No countdown timer on home page")

        countdown_el = driver.find_element(*HomePage.FLASH_SALE_COUNTDOWN)
        initial_text = countdown_el.text
        time.sleep(2)
        updated_text = countdown_el.text
        # Timer should have changed (seconds ticked)
        assert initial_text != updated_text or initial_text == "00:00:00"   
