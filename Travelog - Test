    def test_flash_sale_badge_links_to_tour(self, driver, wait):
        homepage = HomePage(driver)
        homepage.open()

        flash_badges = driver.find_elements(
            By.CSS_SELECTOR, ".flash-sale-badge, [data-testid='flash-badge']"
        )
        if not flash_badges:
            pytest.skip("No flash sale badges on home page")

