"""
test_auth.py — Authentication flows: register, login, logout,
forgot password, token refresh, and protected-route guards.
"""

import time
import pytest
from selenium.webdriver.support import expected_conditions as EC
from selenium.webdriver.common.by import By

from pages import LoginPage, RegisterPage, ForgotPasswordPage, NavBar
from conftest import BASE_URL, TEST_USER_EMAIL, TEST_USER_PASSWORD


class TestLogin:
    """Login page — happy path and error states."""

    def test_login_page_loads(self, driver, wait):
        page = LoginPage(driver)
        page.open()
        assert "login" in driver.current_url.lower() or "sign" in driver.title.lower()
        assert driver.find_element(*LoginPage.EMAIL_FIELD).is_displayed()
        assert driver.find_element(*LoginPage.PASSWORD_FIELD).is_displayed()
        assert driver.find_element(*LoginPage.SUBMIT_BTN).is_displayed()

    def test_login_with_valid_credentials(self, driver, wait):
        page = LoginPage(driver)
        page.open()
        page.login(TEST_USER_EMAIL, TEST_USER_PASSWORD)

        # Should redirect away from login — typically to home or dashboard
        wait.until(EC.url_changes(f"{BASE_URL}/login"))
        assert "/login" not in driver.current_url

    def test_login_shows_error_for_wrong_password(self, driver, wait):
        page = LoginPage(driver)
        page.open()
        page.login(TEST_USER_EMAIL, "WrongPassword999!")

        error_el = wait.until(
            EC.visibility_of_element_located(LoginPage.ERROR_MSG)
        )
        error_text = error_el.text.lower()
        assert any(kw in error_text for kw in ["incorrect", "invalid", "wrong", "failed"])

    def test_login_shows_error_for_unknown_email(self, driver, wait):
        page = LoginPage(driver)
        page.open()
        page.login("nobody@nonexistent-domain-xyz.com", "SomePass123!")

        error_el = wait.until(
            EC.visibility_of_element_located(LoginPage.ERROR_MSG)
        )
        assert error_el.is_displayed()

    def test_login_empty_fields_prevented(self, driver, wait):
        page = LoginPage(driver)
        page.open()
        driver.find_element(*LoginPage.SUBMIT_BTN).click()
        # Should stay on login page and show HTML5 validation or custom error
        assert "/login" in driver.current_url or driver.find_element(*LoginPage.EMAIL_FIELD).get_attribute("validationMessage")

    def test_login_invalid_email_format(self, driver, wait):
        page = LoginPage(driver)
        page.open()
        driver.find_element(*LoginPage.EMAIL_FIELD).send_keys("not-an-email")
        driver.find_element(*LoginPage.PASSWORD_FIELD).send_keys("SomePass123!")
        driver.find_element(*LoginPage.SUBMIT_BTN).click()
        # Browser validates email format or app shows error
        email_validation = driver.find_element(*LoginPage.EMAIL_FIELD).get_attribute("validationMessage")
        assert email_validation or "/login" in driver.current_url

    def test_forgot_password_link_navigates(self, driver, wait):
        page = LoginPage(driver)
        page.open()
        page.click_forgot_password()
        assert "forgot" in driver.current_url.lower() or "reset" in driver.current_url.lower()

    def test_register_link_navigates(self, driver, wait):
        page = LoginPage(driver)
        page.open()
        page.click(*LoginPage.REGISTER_LINK)
        wait.until(EC.url_contains("register"))
        assert "register" in driver.current_url.lower()

    def test_password_field_is_masked(self, driver, wait):
        page = LoginPage(driver)
        page.open()
        pwd_field = driver.find_element(*LoginPage.PASSWORD_FIELD)
        assert pwd_field.get_attribute("type") == "password"


