class SearchPage(BasePage):
    URL = "/search"

    SEARCH_INPUT       = (By.CSS_SELECTOR, "input[name='q'], #search-input")
    FILTER_TOURS_BTN   = (By.CSS_SELECTOR, "[data-filter='tour'], button[value='tour']")
    FILTER_PACKAGES_BTN= (By.CSS_SELECTOR, "[data-filter='holiday_package'], button[value='holiday_package']")
    PRICE_MIN          = (By.CSS_SELECTOR, "input[name='min_price'], #min-price")
    PRICE_MAX          = (By.CSS_SELECTOR, "input[name='max_price'], #max-price")
    FLASH_SALE_TOGGLE  = (By.CSS_SELECTOR, "input[name='is_flash_sale'], #flash-sale-filter")
    SORT_SELECT        = (By.CSS_SELECTOR, "select[name='sort_by'], #sort-select")
    APPLY_FILTERS_BTN  = (By.CSS_SELECTOR, "[data-testid='apply-filters'], .apply-filters-btn")
    CLEAR_FILTERS_BTN  = (By.CSS_SELECTOR, "[data-testid='clear-filters'], .clear-filters-btn")
    RESULT_CARDS       = (By.CSS_SELECTOR, ".search-result-card, [data-testid='result-card']")
    RESULT_COUNT_LABEL = (By.CSS_SELECTOR, ".result-count, [data-testid='result-count']")
    NO_RESULTS_MSG     = (By.CSS_SELECTOR, ".no-results, [data-testid='no-results']")
    PAGINATION_NEXT    = (By.CSS_SELECTOR, "[aria-label='Next page'], .pagination-next")

    def open(self, query: str = ""):
        path = f"{self.URL}?q={query}" if query else self.URL
        self.navigate(path)
        return self

    def search(self, query: str):
        self.type_into(*self.SEARCH_INPUT, query)
        self.driver.find_element(*self.SEARCH_INPUT).send_keys(Keys.RETURN)
        time.sleep(1)

    def get_result_count(self) -> int:
        return len(self.find_all(*self.RESULT_CARDS))

    def get_result_count_label(self) -> str:
        return self.find(*self.RESULT_COUNT_LABEL).text

    def filter_by_price(self, min_price: str, max_price: str):
        if min_price:
            self.type_into(*self.PRICE_MIN, min_price)
        if max_price:
            self.type_into(*self.PRICE_MAX, max_price)
        self.click(*self.APPLY_FILTERS_BTN)
        time.sleep(1)

    def filter_flash_sale_only(self):
        self.click(*self.FLASH_SALE_TOGGLE)
        self.click(*self.APPLY_FILTERS_BTN)
        time.sleep(1)

    def sort_by(self, option: str):
        """option: 'newest', 'price_asc', 'price_desc', 'rating'"""
        select = Select(self.find(*self.SORT_SELECT))
        select.select_by_value(option)
        time.sleep(1)

    def click_result(self, index: int = 0):
        cards = self.find_all(*self.RESULT_CARDS)
        self.scroll_to(cards[index])
        cards[index].click()

    def go_to_next_page(self):
        self.click(*self.PAGINATION_NEXT)
        time.sleep(1)


